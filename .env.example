# First free port starting from PORT (default 3000). If 3000 is busy, uses 3001, etc.
PORT=3000

# aria2 JSON-RPC: if a daemon already responds here, it is reused; otherwise the first
# free port from this value upward is used to spawn aria2c.
ARIA2_RPC_PORT=6800

# Optional secret — if set, must match aria2c --rpc-secret
# ARIA2_RPC_SECRET=

# Default folder when the UI sends an empty path (server-side)
# DOWNLOAD_DIR=

# Set to 0 to never open Chrome automatically. In production, browser opens only if OPEN_BROWSER=1.
# OPEN_BROWSER=1
